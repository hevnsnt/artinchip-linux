#!/bin/bash
# tinyscreen - ArtInChip USB bar display driver
# Wrapper that handles sudo automatically for USB access

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PYTHON="${SCRIPT_DIR}/tinyscreen.py"

# --off and --status don't need sudo
case "$*" in
    *--off*|*--status*)
        exec python3 "$PYTHON" "$@"
        ;;
esac

# Everything else needs root for USB access
if [ "$(id -u)" -ne 0 ]; then
    exec sudo python3 "$PYTHON" "$@"
fi

exec python3 "$PYTHON" "$@"
